@page "/"

<div class="home-hero">
    <div class="home-dots-bg"></div>
    <div class="home-hero-inner">
        <div class="home-hero-content">
            <div class="home-badge">
                <span class="home-badge-dot"></span>
                Now supporting Minecraft
            </div>
            <h1 class="home-title">Host your server.<br /><span>Play your way.</span></h1>
            <p class="home-sub">Deploy game servers in seconds with Docker. No terminal, no config files — just click and play.</p>
            <div class="home-actions">
                <AuthorizeView>
                    <Authorized>
                        <a href="/servers" class="home-btn-primary">Go to my servers</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/register" class="home-btn-primary">Get started free</a>
                        <a href="/login" class="home-btn-ghost">Sign in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <div class="home-hero-visual">
            <svg viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg" class="home-grass-block">
                <!-- Top face (grass) -->
                <polygon points="110,10 210,60 110,110 10,60" fill="#5b8a3c" />
                <polygon points="110,10 210,60 110,110 10,60" fill="url(#grassTop)" />
                <!-- Left face (dirt) -->
                <polygon points="10,60 110,110 110,210 10,160" fill="#6b4c2a" />
                <!-- Right face (dirt lighter) -->
                <polygon points="210,60 110,110 110,210 210,160" fill="#7d5a35" />
                <!-- Grass side left -->
                <polygon points="10,60 110,110 110,125 10,75" fill="#4a7a2a" />
                <!-- Grass side right -->
                <polygon points="210,60 110,110 110,125 210,75" fill="#3d6622" />
                <!-- Grid lines top -->
                <line x1="60" y1="35" x2="160" y2="85" stroke="rgba(0,0,0,0.15)" stroke-width="0.5" />
                <line x1="10" y1="60" x2="210" y2="60" stroke="rgba(0,0,0,0.1)" stroke-width="0.5" />
                <!-- Dirt texture dots left -->
                <circle cx="40" cy="130" r="3" fill="rgba(0,0,0,0.12)" />
                <circle cx="70" cy="155" r="2" fill="rgba(0,0,0,0.1)" />
                <circle cx="55" cy="175" r="3.5" fill="rgba(0,0,0,0.1)" />
                <circle cx="85" cy="145" r="2" fill="rgba(0,0,0,0.08)" />
                <!-- Dirt texture dots right -->
                <circle cx="155" cy="130" r="3" fill="rgba(0,0,0,0.12)" />
                <circle cx="175" cy="155" r="2" fill="rgba(0,0,0,0.1)" />
                <circle cx="145" cy="170" r="3.5" fill="rgba(0,0,0,0.1)" />
                <circle cx="185" cy="145" r="2" fill="rgba(0,0,0,0.08)" />
            </svg>

            <div class="home-server-card-preview">
                <div class="hscp-dot online"></div>
                <div class="hscp-info">
                    <span class="hscp-name">Survival World</span>
                    <span class="hscp-status">● Online</span>
                </div>
                <div class="hscp-players">3/20</div>
            </div>

            <div class="home-server-card-preview offset">
                <div class="hscp-dot offline"></div>
                <div class="hscp-info">
                    <span class="hscp-name">Creative Hub</span>
                    <span class="hscp-status offline">● Offline</span>
                </div>
                <div class="hscp-players dim">0/20</div>
            </div>
        </div>
    </div>
</div>

<div class="home-mc-banner">
    <div class="home-mc-left">
        <p class="home-mc-tag">⛏ Minecraft</p>
        <p class="home-mc-title">Every edition supported</p>
        <p class="home-mc-sub">Java, Fabric, NeoForge — all ready to deploy</p>
    </div>
    <div class="home-mc-pills">
        <span class="home-mc-pill">Java</span>
        <span class="home-mc-pill">Fabric</span>
        <span class="home-mc-pill">NeoForge</span>
    </div>
</div>