@page "/server/{ServerId}/config"
@attribute [Authorize]

@if (!Loading && gameServer == null)
{
    <NotFound />
}
else if (gameServer != null)
{
    <div class="container mt-4">
        <ServerNavigation ServerId="@ServerId">

            <div class="config-wrapper">

                <h2 class="text-nowrap mb-3">Server Configuration</h2>

                <!-- GENERAL SETTINGS -->
                <div class="config-section">
                    <h3>General Settings</h3>

                    <div class="mb-3">
                        <label class="form-label">Server Name</label>
                        <input type="text" class="form-control config-input" value="@gameServer.ServerName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Max Players</label>
                        <input type="number" class="form-control config-input" />
                    </div>
                </div>

                <!-- PERFORMANCE SETTINGS -->
                <div class="config-section">
                    <h3>Performance</h3>

                    <div class="mb-3">
                        <label class="form-label">Memory (MB)</label>
                        <input type="number" class="form-control config-input" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">CPU Limit (%)</label>
                        <input type="number" class="form-control config-input" />
                    </div>
                </div>

                <!-- SAVE BUTTON -->
                <button class="btn config-save-btn">Save Changes</button>

            </div>

        </ServerNavigation>
    </div>
}

@code {
    [Inject] public GameServerService GameServerService { get; set; } = default!;
    [Inject] public UserContext UserContext { get; set; } = default!;

    [Parameter] public string ServerId { get; set; } = default!;
    private ListGameServer? gameServer { get; set; }
    private bool Loading = true;

    protected override async Task OnInitializedAsync()
    {
        var userId = UserContext.GetSignedInUser()!.Id;
        if (Guid.TryParse(ServerId, out var serverId))
        {
            gameServer = await GameServerService.GetByIdAsync(userId, serverId);
        }
        Loading = false;
    }
}
