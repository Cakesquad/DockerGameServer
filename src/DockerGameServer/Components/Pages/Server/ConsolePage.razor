@implements IDisposable
@page "/server/{ServerId}/console"
@attribute [Authorize]

@if (!Loading && gameServer == null)
{
    <NotFound />
}
else if (gameServer != null)
{
    <div class="container mt-4">
        <ServerNavigation ServerId="@ServerId">
            <div class="console-wrapper">
                <pre @ref="LogBox" class="border rounded mb-3" style="height:400px; overflow-y:auto; background:#111; color:#0f0; padding:10px;">
                @foreach (var line in LogLines)
                {
                    @line
                    <br />
                }
            </pre>

                <EditForm Model="this" OnSubmit="SendCommandAsync">
                    <div class="d-flex gap-3">
                        <input type="text" @bind="Command" class="form-control console-input" />
                        <button class="btn console-send-btn">Send</button>
                    </div>
                </EditForm>
            </div>
        </ServerNavigation>
    </div>
}

@code {
    [Inject] public DockerService DockerService { get; set; } = default!;
    [Inject] public UserContext UserContext { get; set; } = default!;
    [Inject] public IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] public GameServerService GameServerService { get; set; } = default!;

    [Parameter] public string ServerId { get; set; } = default!;

    private ListGameServer? gameServer { get; set; }
    private bool Loading = true;
    private bool HasRendered = false;

    private string? ContainerId;
    private string Command = string.Empty;

    private List<string> LogLines = new();
    private CancellationTokenSource? _cts;

    private ElementReference LogBox;

    protected override async Task OnInitializedAsync()
    {
        var userId = UserContext.GetSignedInUser()!.Id;
        if (Guid.TryParse(ServerId, out var serverId))
        {
            gameServer = await GameServerService.GetByIdAsync(userId, serverId);
        }
        Loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!HasRendered)
        {
            HasRendered = true;
            // Quick hack to get container ID from server ID
            ContainerId = await DockerService.GetContainerIdByNameAsync($"gameserver-{ServerId}");
            if (ContainerId == null)
            {
                LogLines.Add("Server not found.");
                return;
            }

            _cts = new CancellationTokenSource();

            // 1. Hent historik
            var history = await DockerService.GetContainerLogsAsync(ContainerId, _cts.Token);
            LogLines = history.Split('\n').ToList();
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();

            // 2. Start live streaming
            _ = Task.Run(async () =>
            {
                await foreach (var line in DockerService.StreamContainerLogsAsync(ContainerId, _cts.Token))
                {
                    LogLines.Add(line);
                    await InvokeAsync(StateHasChanged);
                    await ScrollToBottom();
                }
            });
        }
    }

    private async Task ScrollToBottom()
    {
        await JSRuntime.InvokeVoidAsync("scrollToBottom", LogBox);
    }

    private async Task SendCommandAsync()
    {
        if (ContainerId == null || string.IsNullOrWhiteSpace(Command)) return;
        await DockerService.ExecRconCommandAsync(ContainerId, Command);
        Command = string.Empty;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
